{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "yarn build",
  "outputDirectory": "dist/client",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/agents/:path*",
      "destination": "http://159.89.82.159:8001/api/agents/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/_shell.html"
    }
  ]
}
