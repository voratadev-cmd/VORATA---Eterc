# Agente "Adm Contratual IA" · copie para agent/.env (gitignored) e preencha.

# ── Supabase (projeto vorata) ──────────────────────────────────────
SUPABASE_URL=https://SUPABASE_REF_ETERC_AQUI.supabase.co
# service_role (a "Secret key" sb_secret_... do painel) · bypassa RLS.
# Settings → API Keys → Secret keys. NUNCA no front, NUNCA no git.
SUPABASE_SERVICE_KEY=sb_secret_xxx

# ── Segredo da API (frontend → agente) ─────────────────────────────
# String forte aleatória. O front manda `Authorization: Bearer <VPS_SECRET>`.
VPS_SECRET=troque-por-um-segredo-forte

# ── Auth do Claude ─────────────────────────────────────────────────
# DEV LOCAL: deixe ANTHROPIC_API_KEY VAZIO → o claude-agent-sdk usa o
#   OAuth do Claude Code CLI (você já está logado · custo zero de token).
# PRODUÇÃO (VPS): defina ANTHROPIC_API_KEY → usa a API (paga por token,
#   sancionado pra uso comercial, escala). É o único interruptor: setou = API.
# ANTHROPIC_API_KEY=sk-ant-...

# Modelo PADRÃO de todas as fases com LLM (mapeamento, extração, IA). Opus 4.8 sempre
# (default no config.py) · só sobrescreva aqui se houver razão explícita.
AGENT_MODEL=claude-opus-4-8

# ── Extração (Fase 2) ──────────────────────────────────────────────
# Modelos (default = MAPPER_MODEL/EXTRACTOR_MODEL). Em dev/OAuth = Opus 4.8.
# EXTRACTOR_MODEL=claude-opus-4-8
# VERIFIER_MODEL=claude-opus-4-8
# Verifier (QA · relê o doc e confere). +1 chamada por doc; "0" desliga.
EXTRACTOR_VERIFY=1
# Turnos por chamada (o envelope é montado por MUITAS tool-calls → alto é normal).
EXTRACTOR_MAX_TURNS=220
# Fatiamento (evita estourar contexto de ENTRADA em docs enormes):
PDF_WHOLE_MAX_PAGES=30          # PDF até N páginas = 1 chamada; acima, fatia
XLSX_WHOLE_MAX_CELLS=4000       # planilha até N células = 1 chamada; acima, por sheet
SHEET_SLICE_CELLS=12000         # sheet acima disso = janelas de linhas
EXTRACTOR_MAX_SLICES=60         # teto de fatias/doc (acima → needs_review)
# OCR: precisa do binário no host → macOS: brew install tesseract tesseract-lang
OCR_LANG=por
PDF_RASTER_SCALE=2.0
# Lease/retry da fila (a RPC usa contador próprio por fase; reaper destrava presos).
LEASE_TIMEOUT_MIN=10

# ── Servidor ───────────────────────────────────────────────────────
# Origens permitidas no CORS (front local + prod). Separadas por vírgula.
CORS_ORIGINS=http://localhost:8080,http://localhost:5173
PORT=8000
